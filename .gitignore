# Root .gitignore for Flower Guardian Project

# ===============================
# Frontend (React Native)
# ===============================
frontend/node_modules/
frontend/.bundle/
frontend/*.jsbundle
frontend/coverage/
frontend/.metro-health-check*
frontend/yarn-error.log

# iOS
frontend/ios/build/
frontend/ios/*.xcuserstate
frontend/ios/Pods/
frontend/ios/DerivedData/

# Android
frontend/android/build/
frontend/android/.gradle/
frontend/android/local.properties

# ===============================
# Backend (Python)
# ===============================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
.venv/

# Environment variables
.env
.env.local

# Database
*.db
*.sqlite

# Logs
*.log
logs/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Backend specific
backend/__pycache__/
backend/.env
backend/*.pt
backend/models/runs/
backend/dataset/data/
backend/dataset/
backend/dataset/processed/
backend/dataset/augmented/
backend/dataset/split/

